# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://nobrainfitapp:password@localhost:5432/nobrainfitapp"

# ── Auth (generate with: openssl rand -base64 32) ─────────────────────────────
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ── Admin credentials (used only for seed — change after first login) ─────────
ADMIN_EMAIL="admin@nobrainfitapp.com"
ADMIN_PASSWORD="changeme123"

# ── App API token (used by Flutter app to call /api/app/*) ───────────────────
# Generate with: openssl rand -hex 32
APP_API_TOKEN="change-me-in-production"

# ── Note: Ollama, Claude, Fitness API keys are stored in the database ─────────
# They are managed via the admin panel → Configuration → APIs
