# ── This file is auto-generated by scripts/setup.sh ──────────────────────────
# You normally don't edit it by hand — run `bash scripts/setup.sh` instead.

# ── Deployment ────────────────────────────────────────────────────────────────
# docker-compose.yml (local/HTTP) or docker-compose.prod.yml (Nginx + HTTPS)
COMPOSE_FILE=docker-compose.yml

# ── Database (PostgreSQL, runs in Docker) ─────────────────────────────────────
POSTGRES_DB=nobrainfit
POSTGRES_USER=nobrainfit
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_PORT=5432
DATABASE_URL="postgresql://nobrainfit:CHANGE_ME@localhost:5432/nobrainfit"

# ── App ───────────────────────────────────────────────────────────────────────
APP_PORT=3000
NEXTAUTH_URL="http://localhost:3000"

# ── Auth secrets (generated automatically by setup.sh) ────────────────────────
NEXTAUTH_SECRET="CHANGE_ME"
APP_API_TOKEN="CHANGE_ME"

# ── Admin account (created by the seed on first setup) ────────────────────────
ADMIN_NAME="Admin"
ADMIN_EMAIL="admin@nobrainfit.app"
ADMIN_PASSWORD="CHANGE_ME"

# ── SSL / TLS (production only) ───────────────────────────────────────────────
# SSL_MODE: none | self-signed | letsencrypt
SSL_MODE=none
SSL_DOMAIN=localhost
SSL_EMAIL=
SSL_STAGING=false

# ── Note: Ollama / Claude / Fitness API keys are NOT stored here ──────────────
# They live in the database and are managed in the admin panel → Configuration.
